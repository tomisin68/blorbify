rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /stores/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /publicStores/{storeSlug} {
      allow read: if resource.data.published == true || isOwner(resource.data.ownerId);
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && (!resource.data.keys().hasAny(['ownerId']) || resource.data.ownerId == request.auth.uid);
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /publicStores/{storeSlug}/reviews/{reviewId} {
      allow read: if get(/databases/$(database)/documents/publicStores/$(storeSlug)).data.published == true
        || isOwner(get(/databases/$(database)/documents/publicStores/$(storeSlug)).data.ownerId);
      allow create: if request.resource.data.keys().hasAll(['productId', 'rating', 'comment', 'customerName', 'createdAt'])
        && request.resource.data.productId is string && request.resource.data.productId.size() > 0
        && request.resource.data.rating is int && request.resource.data.rating >= 1 && request.resource.data.rating <= 5
        && request.resource.data.comment is string && request.resource.data.comment.size() <= 500
        && request.resource.data.customerName is string && request.resource.data.customerName.size() <= 80
        && exists(/databases/$(database)/documents/publicStores/$(storeSlug))
        && get(/databases/$(database)/documents/publicStores/$(storeSlug)).data.published == true;
      allow update, delete: if isSignedIn()
        && get(/databases/$(database)/documents/publicStores/$(storeSlug)).data.ownerId == request.auth.uid;
    }

    // Abandoned-cart snapshots written by anonymous storefront visitors so the
    // backend can nudge them by email later. No `read` rule at all — buyer
    // emails/carts here must not be exposed to the public, only the backend's
    // admin SDK (which bypasses rules) reads this collection.
    match /cartSnapshots/{snapshotId} {
      allow read: if false;
      allow create, update: if request.resource.data.keys().hasAll(['storeSlug', 'customerEmail', 'items', 'updatedAt'])
        && request.resource.data.storeSlug is string && request.resource.data.storeSlug.size() > 0
        && request.resource.data.customerEmail is string && request.resource.data.customerEmail.size() > 0
        && request.resource.data.items is list
        && exists(/databases/$(database)/documents/publicStores/$(request.resource.data.storeSlug))
        && get(/databases/$(database)/documents/publicStores/$(request.resource.data.storeSlug)).data.published == true;
      allow delete: if true;
    }

    match /orders/{orderId} {
      allow read: if isSignedIn() && resource.data.storeId == request.auth.uid;
      allow create: if request.resource.data.keys().hasAll([
          'storeId',
          'storeSlug',
          'items',
          'total',
          'customerName',
          'customerPhone',
          'customerAddress',
          'status'
        ])
        && request.resource.data.status == 'pending'
        && exists(/databases/$(database)/documents/publicStores/$(request.resource.data.storeSlug))
        && get(/databases/$(database)/documents/publicStores/$(request.resource.data.storeSlug)).data.published == true
        && get(/databases/$(database)/documents/publicStores/$(request.resource.data.storeSlug)).data.ownerId == request.resource.data.storeId;
      allow update: if isSignedIn() && resource.data.storeId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.storeId == request.auth.uid;
    }

    // Invoices are only ever written by the backend (admin SDK, which bypasses
    // these rules) so the stored doc, the emailed PDF, and the sent email stay
    // in sync — the client only reads its own list of invoices.
    match /invoices/{invoiceId} {
      allow read: if isSignedIn() && resource.data.sellerId == request.auth.uid;
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
