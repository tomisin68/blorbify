rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Products may only be listed once a seller has an active paid plan (set by
    // the backend on successful Paystack payment, or by an admin override —
    // see backend/src/services/billing.service.js applyManualActivation). Reads
    // the seller's own users/{userId} doc, which every seller can already read.
    function hasActiveSubscription(userId) {
      return exists(/databases/$(database)/documents/users/$(userId))
        && get(/databases/$(database)/documents/users/$(userId)).data.get('subscription', {}).get('status', '') == 'active';
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /stores/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId)
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['products'])
          || hasActiveSubscription(userId)
        );
      allow delete: if isOwner(userId);
    }

    match /publicStores/{storeSlug} {
      // `resource == null` handles reading a slug that doesn't exist yet (e.g.
      // checking whether a new store URL is available before claiming it) —
      // without this, referencing resource.data on a nonexistent doc errors
      // out during rule evaluation, which Firestore treats as a denial rather
      // than "not found". Exposes no data, since there is none to expose.
      allow read: if resource == null || resource.data.published == true || isOwner(resource.data.ownerId);
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && (request.resource.data.products.size() == 0 || hasActiveSubscription(request.auth.uid));
      allow update: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && (!resource.data.keys().hasAny(['ownerId']) || resource.data.ownerId == request.auth.uid)
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['products'])
          || hasActiveSubscription(request.auth.uid)
        );
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /publicStores/{storeSlug}/reviews/{reviewId} {
      allow read: if get(/databases/$(database)/documents/publicStores/$(storeSlug)).data.published == true
        || isOwner(get(/databases/$(database)/documents/publicStores/$(storeSlug)).data.ownerId);
      allow create: if request.resource.data.keys().hasAll(['productId', 'rating', 'comment', 'customerName', 'createdAt'])
        && request.resource.data.productId is string && request.resource.data.productId.size() > 0
        && request.resource.data.rating is int && request.resource.data.rating >= 1 && request.resource.data.rating <= 5
        && request.resource.data.comment is string && request.resource.data.comment.size() <= 500
        && request.resource.data.customerName is string && request.resource.data.customerName.size() <= 80
        && exists(/databases/$(database)/documents/publicStores/$(storeSlug))
        && get(/databases/$(database)/documents/publicStores/$(storeSlug)).data.published == true;
      allow update, delete: if isSignedIn()
        && get(/databases/$(database)/documents/publicStores/$(storeSlug)).data.ownerId == request.auth.uid;
    }

    // Abandoned-cart snapshots written by anonymous storefront visitors so the
    // backend can nudge them by email later. No `read` rule at all — buyer
    // emails/carts here must not be exposed to the public, only the backend's
    // admin SDK (which bypasses rules) reads this collection.
    match /cartSnapshots/{snapshotId} {
      allow read: if false;
      allow create, update: if request.resource.data.keys().hasAll(['storeSlug', 'customerEmail', 'items', 'updatedAt'])
        && request.resource.data.storeSlug is string && request.resource.data.storeSlug.size() > 0
        && request.resource.data.customerEmail is string && request.resource.data.customerEmail.size() > 0
        && request.resource.data.items is list
        && exists(/databases/$(database)/documents/publicStores/$(request.resource.data.storeSlug))
        && get(/databases/$(database)/documents/publicStores/$(request.resource.data.storeSlug)).data.published == true;
      allow delete: if true;
    }

    // Logistics companies are managed only by the backend's Admin SDK (see
    // backend/src/routes/admin.routes.js), which bypasses these rules —
    // sellers just need read access to browse partners and share orders with them.
    match /logisticsCompanies/{companyId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /orders/{orderId} {
      allow read: if isSignedIn() && resource.data.storeId == request.auth.uid;
      allow create: if request.resource.data.keys().hasAll([
          'storeId',
          'storeSlug',
          'items',
          'total',
          'customerName',
          'customerPhone',
          'status'
        ])
        // Physical orders still need a real delivery address; digital-only
        // carts (see `requiresAddress`, written by the storefront checkout)
        // don't, since there's nothing to ship.
        && (
          request.resource.data.requiresAddress != true
          || (request.resource.data.customerAddress is string && request.resource.data.customerAddress.size() > 0)
        )
        && request.resource.data.status == 'pending'
        && exists(/databases/$(database)/documents/publicStores/$(request.resource.data.storeSlug))
        && get(/databases/$(database)/documents/publicStores/$(request.resource.data.storeSlug)).data.published == true
        && get(/databases/$(database)/documents/publicStores/$(request.resource.data.storeSlug)).data.ownerId == request.resource.data.storeId;
      allow update: if isSignedIn() && resource.data.storeId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.storeId == request.auth.uid;
    }

    // Invoices are only ever written by the backend (admin SDK, which bypasses
    // these rules) so the stored doc, the emailed PDF, and the sent email stay
    // in sync — the client only reads its own list of invoices.
    match /invoices/{invoiceId} {
      allow read: if isSignedIn() && resource.data.sellerId == request.auth.uid;
      allow write: if false;
    }

    // Seller support chat. The admin console never touches Firestore directly
    // — every admin read/write goes through the backend's Admin SDK, which
    // bypasses these rules entirely, so no admin-specific allowance is needed
    // here. Only the seller's own conversation is reachable from the client.
    match /supportConversations/{sellerId} {
      allow read: if isOwner(sellerId);
      allow create: if isOwner(sellerId) && request.resource.data.sellerId == sellerId;
      allow update: if isOwner(sellerId);

      match /messages/{messageId} {
        allow read: if isOwner(sellerId);
        // Only 'seller' and 'bot' — a seller's own client can never write a
        // message impersonating 'admin'. Real admin replies only ever happen
        // via the Admin SDK. No update/delete: messages are immutable once sent.
        allow create: if isOwner(sellerId) && request.resource.data.senderType in ['seller', 'bot'];
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
